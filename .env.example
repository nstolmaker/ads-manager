# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_MCC_CUSTOMER_ID=your_mcc_customer_id
GOOGLE_ADS_ACCOUNT_CUSTOMER_ID=your_sub_account_customer_id

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Postgres
PG_HOST=truenas.local
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_pg_password
PG_DATABASE=ads_manager

# OpenClaw
OPENCLAW_HOOK_TOKEN=your_openclaw_hook_token
OPENCLAW_HOOK_URL=http://127.0.0.1:18789/hooks/agent
DISCORD_CHANNEL_ID=your_ads_manager_channel_id

# Webhook server
WEBHOOK_PORT=9722
WEBHOOK_SECRET=changeme

# App
MODE=hitl
LOOP_INTERVAL_DAYS=7
TOTAL_MONTHLY_BUDGET_USD=500
PERSONA_MIN_BUDGET_PCT=0.10
SEED_IDEA_BUDGET_PCT=0.07
